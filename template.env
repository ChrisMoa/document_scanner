# Nextcloud Configuration

# Your Nextcloud base URL (no trailing slash)
# Example: https://cloud.example.com
NEXTCLOUD_SERVER_URL=

# Your Nextcloud username
NEXTCLOUD_USERNAME=

# A Nextcloud App Password generated in your account security settings
# It is safer to use an app password than your main account password
NEXTCLOUD_APP_PASSWORD=

# Instructions:
# 1. Copy this file to .env in the project root
# 2. Fill in your Nextcloud server URL, username, and an App Password
# 3. In the app: Settings → Cloud & Sync → Nextcloud Integration → Connect
# 4. Never commit the .env file to version control